{
  "name": "guardian",
  "version": "0.1.0",
  "description": "Policy-bound Solana wallet agent with verifiable receipts and LLM wiki audit log",
  "main": "dist/index.js",
  "bin": {
    "guardian": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
